<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ========== 日志根目录：项目运行目录下的 .log ========== -->
    <property name="LOG_HOME" value="${user.dir}/.log"/>

    <!-- ========== 控制台输出 ========== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%-40.40logger{39}) : %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ========== 全量日志文件（INFO 及以上） ========== -->
    <appender name="FILE_ALL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/yumy-boot.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/archive/yumy-boot.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %-40.40logger{39} : %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- ========== ERROR 日志文件（仅 ERROR 级别） ========== -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/yumy-boot-error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/archive/yumy-boot-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %-40.40logger{39} : %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- ========== 第三方框架日志降噪 ========== -->
    <!-- Spring 框架 -->
    <logger name="org.springframework" level="WARN"/>
    <!-- Spring Security -->
    <logger name="org.springframework.security" level="WARN"/>
    <!-- MyBatis / MyBatis-Plus -->
    <logger name="com.baomidou.mybatisplus" level="WARN"/>
    <!-- Redis -->
    <logger name="org.springframework.data.redis" level="WARN"/>
    <!-- Tomcat -->
    <logger name="org.apache.catalina" level="WARN"/>
    <!-- Hibernate Validator -->
    <logger name="org.hibernate.validator" level="WARN"/>

    <!-- ========== 业务日志（开发环境 DEBUG，生产环境 INFO） ========== -->
    <logger name="com.de.food" level="${LOG_LEVEL:-DEBUG}"/>

    <!-- ========== 开发环境：控制台 + 文件 ========== -->
    <springProfile name="dev | default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE_ALL"/>
            <appender-ref ref="FILE_ERROR"/>
        </root>
    </springProfile>

    <!-- ========== 生产环境：仅文件 ========== -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="FILE_ALL"/>
            <appender-ref ref="FILE_ERROR"/>
        </root>
    </springProfile>

</configuration>
